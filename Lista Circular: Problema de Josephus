public class Josephus {
    public static void main(String[] args) {
        int N = 6;
        int M = 3;

        // Passo 1: Monta a lista circular
        Node primeiro = new Node(1);
        Node atual = primeiro;
        for (int i = 2; i <= N; i++) {
            Node novo = new Node(i);  
            atual.next = novo;        
            atual = novo;            
        }
        atual.next = primeiro; // fecha o círculo!

        // Passo 2: Simula a eliminação
        Node anterior = atual;
        atual = primeiro;

        System.out.println("Ordem de eliminacao:");
        while (atual.next != atual) { 
            // avança M-1 vezes
            for (int i = 0; i < M - 1; i++) {
                anterior = atual;
                atual = atual.next;
            }
            // elimina 'atual'
            anterior.next = atual.next;
            System.out.println(atual.item);
            atual = anterior.next; // avança para o próximo após eliminado
        }
        System.out.println("\nSobrevivente: " + atual.item);
    }
}
